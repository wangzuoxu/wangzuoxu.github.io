<main class="page project-page">
  <section class="hero project-hero">
    <div class="project-header">
      <a class="back-link" href="{{ locale.ui.homeHref | url }}">{{ locale.ui.backHome }}</a>
      <p class="eyebrow">{{ project.meta }}</p>
      <h1>{{ project.title }}</h1>
      <p class="project-tag">{{ project.tag }}</p>
      <p class="project-summary">{{ project.text }}</p>
    </div>
  </section>

  <section class="section">
    <div class="section-heading">
      <p class="section-index">01</p>
      <h2>{{ locale.ui.projectDetailsTitle }}</h2>
    </div>
    <div class="section-body">
      <div class="panel project-panel">
        <p>{{ project.text }}</p>
      </div>
      <div class="panel project-panel">
        <h3>{{ locale.ui.demoTitle }}</h3>
        <div class="video-slot">
          <div>
            <p class="video-slot-label">{{ locale.ui.videoLabel }}</p>
            <p>{{ locale.ui.videoText }}</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>
